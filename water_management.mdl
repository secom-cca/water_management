{UTF-8}
Initial company=
	500
	~	
	~		|

Available groundwater= INTEG (
	Groundwater inflow+Percolation+Seepage from deep-Groundwater outflow-Percolation to deep
	-Seepage-Agricultural GW withdraw-Domestic GW withdraw-Industrial GW withdraw,
		Area * Shallow layer thickness * Porosity)
	~	m3
	~		|

Available Surface Water= INTEG (
	Runoff+Seepage+Surface water inflow-Agricultural SW withdraw-Domestic SW withdraw-Evapotranspiration\
		-Industrial SW withdraw-Percolation-Surface water outflow,
		Area * Initial SW depth)
	~	m3
	~		|

Company= INTEG (
	Company inflow-Company outflow,
		Initial company)
	~	
	~		|

Evapotranspiration=
	Evap ratio * Available Surface Water * (1 + Temp sensitivity * (Temperature - 15))
	~	m3/Month
	~		|

Evap ratio=
	0.03
	~	
	~		|

Temp sensitivity=
	0.01
	~	
	~		|

Initial population= INITIAL(
	113676)
	~	person
	~		|

Population= INTEG (
	Population inflow-Population outflow,
		Initial population)
	~	person
	~		|

Agricultural DW return ratio=
	0.1
	~	
	~		|

Agricultural DW withdraw=
	MIN (DW use ratio agri * Agricultural water demand, Deep groundwater)
	~	
	~		|

Deep groundwater return flow=
	Agricultural return flow * Agricultural DW return ratio
	~	
	~		|

Agricultural GW withdraw=
	MIN (GW use ratio agri * Agricultural water demand, Available groundwater)
	~	m3/Month
	~		|

Agricultural return flow=
	Agricultural return ratio * Agricultural water use
	~	m3/Month
	~		|

Agricultural return ratio=
	0.8
	~	 [0,1,0.1]
	~		|

Industrial GW withdraw=
	MIN (Available groundwater, GW use ratio ind*Industrial water demand)
	~	m3/Month
	~		|

Agricultural SW withdraw=
	MIN (Agricultural water demand * SW use ratio agri, Available Surface Water)
	~	m3/Month
	~		|

Industrial return ratio=
	0.9
	~	 [0,1,0.1]
	~		|

Agricultural water use=
	Agricultural DW withdraw + Agricultural GW withdraw + Agricultural SW withdraw
	~	m3/Month
	~		|

Domestic SW withdraw=
	MIN (SW use ratio dom*Domestic water demand, Available Surface Water)
	~	m3/Month
	~		|

Initial SW depth=
	0.1
	~	m
	~		|

Deep groundwater inflow=
	Deep groundwater return flow
	~	m3/Month
	~		|

Deep groundwater outflow=
	Deep groundwater outflow ratio * Deep groundwater
	~	
	~		|

Domestic DW withdraw=
	MIN (DW use ratio dom*Domestic water demand, Deep groundwater)
	~	
	~		|

Surface water return flow=
	Agricultural SW return ratio * Agricultural return flow + Domestic return flow + Industrial return flow
	~	m3/Month
	~		|

Deep groundwater= INTEG (
	Deep groundwater inflow+Percolation to deep-Deep groundwater outflow-Seepage from deep\
		-Agricultural DW withdraw-Domestic DW withdraw-Industrial DW withdraw,
		Area * Deep layer thickness * Deep porosity)
	~	m3
	~		|

Domestic return ratio=
	0.9
	~	 [0,1,0.1]
	~		|

Industrial SW withdraw=
	MIN (SW use ratio ind*Industrial water demand, Available Surface Water)
	~	m3/Month
	~		|

Industrial DW withdraw=
	MIN (Industrial water demand*DW use ratio ind,Deep groundwater)
	~	
	~		|

Groundwater return flow=
	Agricultural GW return ratio * Agricultural return flow
	~	m3/Month
	~		|

Domestic return flow=
	Domestic return ratio * Domestic water use
	~	m3/Month
	~		|

Industrial return flow=
	Industrial return ratio * Industrial water use
	~	m3/Month
	~		|

Domestic GW withdraw=
	MIN (Domestic water demand*GW use ratio dom, Available groundwater)
	~	m3/Month
	~		|

Domestic water use=
	Domestic DW withdraw + Domestic GW withdraw + Domestic SW withdraw
	~	m3/Month
	~		|

Industrial water use=
	Industrial DW withdraw + Industrial GW withdraw + Industrial SW withdraw
	~	m3/Month
	~		|

Agricultural water demand=
	Area*Paddy field area ratio*Irrigation depth
	~	m3/Month
	~		|

Groundwater outflow ratio=
	0.01
	~	 [0,1,0.01]
	~		|

Irrigation depth = WITH LOOKUP (
	    MODULO(Time,12),
		    ( (0,0),
		      (1,0),
		      (2,0),
		      (3,0),
		      (4,0.32),
