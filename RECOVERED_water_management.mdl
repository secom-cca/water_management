		 (21, 25.93), (22, 21.52), (23, 15.51), (24, 10.65)))
	~	
	~		|

Industrial water demand=
	Company * Per capita industrial water demand * 30
	~	
	~		|

Company= INTEG (
	Company inflow-Company outflow,
		1)
	~	
	~		|

Per capita industrial water demand=
	145 * 1e+06 * 0.00378541
	~	m3/day
	~		|

Population= INTEG (
	Population inflow-Population outflow,
		2.038e+07)
	~	
	~		|

Per capita domestic water demand=
	4.5
	~	m3/day [0,10]
	~		|

